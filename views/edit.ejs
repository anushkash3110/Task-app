<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <a class="text-blue-500 inline-block mb-10  py-3" href="/">Go Back to Home</a>
        <form action="/edit" method="post">
                <input class="block w-1/5 rounded-md outline-none text-zinc-500 px-5 py-2 bg-zinc-800"  type="text" placeholder="Previous name" name="previous" value="<%= filename %>" disbaled="true">
                <input class="block mt-2 w-1/5 rounded-md outline-none text-white px-5 py-2 resize-none bg-zinc-800 mt-2" placeholder="New Name" name="new">
                <input class="block mt-2 px-5 py-2 bg-yellow-800 text-white px-5 py-2 rounded-md" type="submit" value="Update Name">
        </form>
    </div>
</body>
</html>